<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="inertial_macros.xacro"/>

<!-- CHASSIS SIZE -->

<xacro:property name="chassis_length" value="0.30"/>
<xacro:property name="chassis_width" value="0.25"/>
<xacro:property name="chassis_height" value="0.10"/>
<xacro:property name="chassis_mass" value="1.0"/>

<!-- WHEEL PARAMETERS -->

<xacro:property name="wheel_radius" value="0.033"/>
<xacro:property name="wheel_thickness" value="0.026"/>
<xacro:property name="wheel_mass" value="0.05"/>

<!-- WHEEL POSITIONS -->

<xacro:property name="rear_wheel_offset_x" value="0.06"/>
<xacro:property name="front_wheel_offset_x" value="0.24"/>

<xacro:property name="wheel_offset_y" value="0.138"/>
<xacro:property name="wheel_offset_z" value="-0.03"/>

<!-- MATERIALS -->

<material name="orange">
<color rgba="1 0.3 0.1 1"/>
</material>

<material name="blue">
<color rgba="0.2 0.2 1 1"/>
</material>

<material name="black">
<color rgba="0 0 0 1"/>
</material>

<!-- BASE -->

<link name="base_footprint"/>

<link name="base_link"/>

<joint name="base_joint" type="fixed">
<parent link="base_footprint"/>
<child link="base_link"/>
<origin xyz="0 0 0"/>
</joint>

<!-- CHASSIS -->

<link name="chassis">

<visual>
<origin xyz="${chassis_length/2} 0 ${chassis_height/2}"/>
<geometry>
<box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
</geometry>
<material name="orange"/>
</visual>

<collision>
<origin xyz="${chassis_length/2} 0 ${chassis_height/2}"/>
<geometry>
<box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
</geometry>
</collision>

<xacro:inertial_box
mass="${chassis_mass}"
x="${chassis_length}"
y="${chassis_width}"
z="${chassis_height}">
<origin xyz="${chassis_length/2} 0 ${chassis_height/2}"/>
</xacro:inertial_box>

</link>

<joint name="chassis_joint" type="fixed">
<parent link="base_link"/>
<child link="chassis"/>
<origin xyz="${-rear_wheel_offset_x} 0 ${-wheel_offset_z}"/>
</joint>

<!-- REAR LEFT WHEEL -->

<link name="rear_left_wheel">

<visual>
<geometry>
<cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
</geometry>
<material name="blue"/>
</visual>

<collision>
<geometry>
<cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
</geometry>
</collision>

<xacro:inertial_cylinder
mass="${wheel_mass}"
length="${wheel_thickness}"
radius="${wheel_radius}">
<origin xyz="0 0 0"/>
</xacro:inertial_cylinder>

</link>

<joint name="rear_left_wheel_joint" type="continuous">

<parent link="chassis"/>
<child link="rear_left_wheel"/>

<origin xyz="${rear_wheel_offset_x} ${wheel_offset_y} ${wheel_offset_z}"
rpy="-${pi/2} 0 0"/>

<axis xyz="0 0 1"/>

</joint>

<!-- REAR RIGHT WHEEL -->

<link name="rear_right_wheel">

<visual>
<geometry>
<cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
</geometry>
<material name="blue"/>
</visual>

<collision>
<geometry>
<cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
</geometry>
</collision>

<xacro:inertial_cylinder
mass="${wheel_mass}"
length="${wheel_thickness}"
radius="${wheel_radius}">
<origin xyz="0 0 0"/>
</xacro:inertial_cylinder>

</link>

<joint name="rear_right_wheel_joint" type="continuous">

<parent link="chassis"/>
<child link="rear_right_wheel"/>

<origin xyz="${rear_wheel_offset_x} ${-wheel_offset_y} ${wheel_offset_z}"
rpy="${pi/2} 0 0"/>

<axis xyz="0 0 -1"/>

</joint>

<!-- FRONT LEFT WHEEL -->

<link name="front_left_wheel">

<visual>
<geometry>
<cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
</geometry>
<material name="blue"/>
</visual>

<collision>
<geometry>
<cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
</geometry>
</collision>

<xacro:inertial_cylinder
mass="${wheel_mass}"
length="${wheel_thickness}"
radius="${wheel_radius}">
<origin xyz="0 0 0"/>
</xacro:inertial_cylinder>

</link>

<joint name="front_left_wheel_joint" type="continuous">

<parent link="chassis"/>
<child link="front_left_wheel"/>

<origin xyz="${front_wheel_offset_x} ${wheel_offset_y} ${wheel_offset_z}"
rpy="-${pi/2} 0 0"/>

<axis xyz="0 0 1"/>

</joint>

<!-- FRONT RIGHT WHEEL -->

<link name="front_right_wheel">

<visual>
<geometry>
<cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
</geometry>
<material name="blue"/>
</visual>

<collision>
<geometry>
<cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
</geometry>
</collision>

<xacro:inertial_cylinder
mass="${wheel_mass}"
length="${wheel_thickness}"
radius="${wheel_radius}">
<origin xyz="0 0 0"/>
</xacro:inertial_cylinder>

</link>

<joint name="front_right_wheel_joint" type="continuous">

<parent link="chassis"/>
<child link="front_right_wheel"/>

<origin xyz="${front_wheel_offset_x} ${-wheel_offset_y} ${wheel_offset_z}"
rpy="${pi/2} 0 0"/>

<axis xyz="0 0 -1"/>

</joint>

<!-- GAZEBO COLORS -->

<gazebo reference="chassis">
<material>Gazebo/Orange</material>
</gazebo>

<gazebo reference="rear_left_wheel">
<material>Gazebo/Blue</material>
</gazebo>

<gazebo reference="rear_right_wheel">
<material>Gazebo/Blue</material>
</gazebo>

<gazebo reference="front_left_wheel">
<material>Gazebo/Blue</material>
</gazebo>

<gazebo reference="front_right_wheel">
<material>Gazebo/Blue</material>
</gazebo>

</robot>